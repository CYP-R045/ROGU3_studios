---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products, type Product } from "../../lib/mockProducts";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { handle: product.handle },
    props: { product },
  }));
}

interface Props { product: Product; }
const { product } = Astro.props;
---

<BaseLayout title={product.title} theme="light">
  <section class="wrap">
    <div class="media">
      <img
        id="mainImg"
        class="img"
        src={product.images?.[0]}
        alt={product.title}
      />

      {
        product.images && product.images.length > 1 && (
          <div class="thumbs" aria-label="Image thumbnails">
            {product.images.map((src, i) => (
              <button
                class="thumb"
                type="button"
                data-src={src}
                aria-label={`View image ${i + 1}`}
              >
                <img src={src} alt="" />
              </button>
            ))}
          </div>
        )
      }
    </div>

    <div class="info">
      <h1>{product.title}</h1>
      <div class="price">{product.price}</div>

      <p class="desc">
        Placeholder product page. Once Shopify is ready, we’ll pull real
        description/variants and wire checkout.
      </p>

      <button class="btn" disabled>Checkout (coming soon)</button>
    </div>
  </section>

  <script>
    const mainImg = document.querySelector("#mainImg");
    const thumbs = document.querySelectorAll(".thumb");
    thumbs.forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-src");
        if (mainImg && src) mainImg.setAttribute("src", src);
      });
    });
  </script>

  <style>
    .wrap {
      padding: 48px 22px;
      max-width: 1000px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .media {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .img {
      width: 100%;
      border-radius: 18px;
      object-fit: cover;
      background: rgba(0, 0, 0, 0.05);
    }
    .thumbs {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .thumb {
      border: 0;
      padding: 0;
      border-radius: 12px;
      overflow: hidden;
      width: 86px;
      height: 86px;
      cursor: pointer;
      background: transparent;
    }
    .thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    h1 {
      margin: 0 0 10px;
      font-size: 36px;
    }
    .price {
      font-weight: 800;
      margin-bottom: 14px;
    }
    .desc {
      opacity: 0.85;
      line-height: 1.6;
    }
    .btn {
      margin-top: 18px;
      padding: 12px 16px;
      border-radius: 14px;
      border: 0;
      background: #000;
      color: #fff;
      opacity: 0.5;
      cursor: not-allowed;
    }
    @media (max-width: 900px) {
      .wrap {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
