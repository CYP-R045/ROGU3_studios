---
import BaseLayout from "../layouts/BaseLayout.astro";

const socials = [
  { name: "Instagram", handle: "@rogu3", href: "https://instagram.com/rogu3" },
  { name: "TikTok", handle: "@rogu3", href: "https://tiktok.com/@rogu3" },
  { name: "X", handle: "@rogu3", href: "https://x.com/rogu3" },
  { name: "YouTube", handle: "ROGU3", href: "https://youtube.com/@rogu3" },
];
---

<BaseLayout title="Story" theme="light">
  <section class="story">
    <div class="overlay" aria-hidden="true"></div>

    <header class="top">
      <h1>The Story</h1>
      <p class="sub">Vancouver-born. Built from the grind — and the vision.</p>
    </header>

    <article class="panel" aria-label="ROGU3 brand story">
      <h2>How ROGU3 started</h2>
      <p>
        ROGU3 began as a simple idea: build something that feels like the city —
        the late nights, the quiet confidence, the pressure to level up, and the
        people who keep moving anyway.
      </p>
      <p>
        The brand is for the ones who don’t need to announce themselves. It’s
        streetwear, but sharper. Limited pieces, real design, and a world you
        can step into — not just a logo on fabric.
      </p>

      <div class="divider"></div>

      <div class="socials">
        <div class="label">Follow the drop alerts</div>
        <div class="links">
          {
            socials.map((s) => (
              <a class="social" href={s.href} target="_blank" rel="noreferrer">
                <span class="name">{s.name}</span>
                <span class="handle">{s.handle}</span>
                <span class="arrow">↗</span>
              </a>
            ))
          }
        </div>
      </div>
    </article>
  </section>

  <style>
    .story {
      position: relative;
      min-height: 100vh;
      padding: 44px 28px;
      overflow: hidden;

      background-image: url("/Faded_rogu3.jpg");
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }

    /* soft cinematic contrast */
    .overlay {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          900px 500px at 20% 20%,
          rgba(0, 0, 0, 0.1),
          transparent 60%
        ),
        radial-gradient(
          900px 500px at 80% 30%,
          rgba(0, 0, 0, 0.18),
          transparent 60%
        ),
        linear-gradient(180deg, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.55));
      z-index: 0;
      pointer-events: none;
    }

    .top {
      position: relative;
      z-index: 2;
      max-width: 640px;
    }
    .kicker {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.16);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: rgba(255, 255, 255, 0.92);
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-size: 12px;
    }
    h1 {
      margin: 14px 0 6px;
      font-size: 56px;
      line-height: 1.04;
      letter-spacing: -0.03em;
      color: rgba(255, 255, 255, 0.96);
      text-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    .sub {
      margin: 0;
      color: rgba(255, 255, 255, 0.8);
      font-weight: 600;
      max-width: 52ch;
    }

    /* glass panel */
    .panel {
      position: absolute;
      right: 4%;
      bottom: 8%;
      width: min(720px, 92vw);
      z-index: 2;

      border-radius: 26px;
      padding: 20px 20px 18px;
      background: rgba(0, 0, 0, 0.28);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: 0 22px 60px rgba(0, 0, 0, 0.35);
    }

    .panel h2 {
      margin: 0 0 10px;
      color: rgba(255, 255, 255, 0.95);
      letter-spacing: -0.02em;
      font-size: 18px;
    }
    .panel p {
      margin: 0 0 10px;
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.55;
      font-weight: 550;
      font-size: 14px;
      max-width: 70ch;
    }

    .divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.14);
      margin: 14px 0;
    }

    .label {
      color: rgba(255, 255, 255, 0.7);
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-size: 12px;
      margin-bottom: 10px;
    }

    .links {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .social {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 12px;
      border-radius: 16px;
      text-decoration: none;

      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      transition:
        transform 0.15s ease,
        background 0.15s ease,
        border-color 0.15s ease;
    }
    .social:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.09);
      border-color: rgba(255, 255, 255, 0.22);
    }

    .name {
      color: rgba(255, 255, 255, 0.92);
      font-weight: 800;
      font-size: 13px;
    }
    .handle {
      color: rgba(255, 255, 255, 0.68);
      font-weight: 700;
      font-size: 12px;
      margin-left: auto;
    }
    .arrow {
      color: rgba(255, 255, 255, 0.75);
      font-weight: 900;
    }

    /* responsive */
    @media (max-width: 980px) {
      .panel {
        position: relative;
        right: auto;
        bottom: auto;
        margin-top: 22px;
      }
      h1 {
        font-size: 44px;
      }
      .links {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
