import React, { useRef, useLayoutEffect, useEffect } from "react";
import gsap from "gsap";
import * as THREE from "three";
import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
import FloatingNav from "./FloatingNav";

interface HeroProps {
  isDarkMode: boolean;
}

interface Shard {
  mesh: THREE.Mesh;
  velocity: THREE.Vector3;
  rotSpeed: THREE.Vector3;
  opacity: number;
  faderate?: number;
}

const Hero: React.FC<HeroProps> = ({ isDarkMode }) => {
  const containerRef = useRef<HTMLDivElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const contentRef = useRef<HTMLDivElement>(null);
  const rotationVelocityRef = useRef(0);
  const lastDeltaXRef = useRef(0);

  const isDraggingRef = useRef(false);
  const lastPointerXRef = useRef(0);
  const lastPointerYRef = useRef(0);
  const dragRotationYRef = useRef(0);
  const cameraTargetZRef = useRef(0);
  const gestureAxisRef = useRef<"x" | "y" | null>(null);
  const swipeStartXRef = useRef(0);
  const swipeStartYRef = useRef(0);
  const rogueRef = useRef<THREE.Object3D | null>(null);
  const shardsRef = useRef<Shard[]>([]);
  const logoMeshRef = useRef<THREE.Mesh | null>(null);
  const sceneRef = useRef<THREE.Scene | null>(null);
  const rendererRef = useRef<THREE.WebGLRenderer | null>(null);
  const cameraRef = useRef<THREE.PerspectiveCamera | null>(null);
  const segmentsRef = useRef<THREE.Group[]>([]);
  const loadOverlayRef = useRef<HTMLDivElement>(null);
  const loadedCountRef = useRef(0);
  const textureCacheRef = useRef<THREE.Texture[]>([]);

  const TUNNEL_WIDTH = 24;
  const TUNNEL_HEIGHT = 16;
  const SEGMENT_DEPTH = 5;
  const NUM_SEGMENTS = 20;
  const FOG_DENSITY = 0.025;
  const FLOOR_COLS = 3;
  const WALL_ROWS = 3;
  const COL_WIDTH = TUNNEL_WIDTH / FLOOR_COLS;
  const ROW_HEIGHT = TUNNEL_HEIGHT / WALL_ROWS;

  const imageUrls = [
    "/brand/Placeholder_H1.webp",
    "/brand/Placeholder_H2.webp",
    "/brand/Placeholder_H3.webp",
    "/brand/Placeholder_H4.webp",
    "/brand/Placeholder_H5.webp",
    "/brand/Placeholder_H6.webp",
    "/brand/Placeholder_H7.webp",
    "/brand/Placeholder_H9.webp",
    "/brand/PlaceholderH10.webp",
    "/brand/Placeholder_H11.webp",
    "/brand/Placeholder_rogu3demon.webp",
    "/brand/P_rogu3.webp",
    "/brand/Pink_ai.webp",
  ];

  // --- GLASS SHATTER ---
  const shatterCharacter = (character: THREE.Object3D, scene: THREE.Scene): Shard[] => {
    const shards: Shard[] = [];

    character.updateMatrixWorld(true);
    const box = new THREE.Box3().setFromObject(character);
    const size = box.getSize(new THREE.Vector3());
    const center = box.getCenter(new THREE.Vector3());

    // Mix of large chunks (few) + medium shards + tiny splinters
    const shardDefs = [
      { count: 12, minSize: 0.80, maxSize: 1.40, speedMult: 0.6 },  // big chunks
      { count: 40, minSize: 0.40, maxSize: 0.80, speedMult: 1.0 },  // medium
      { count: 60, minSize: 0.18, maxSize: 0.42, speedMult: 1.5 },  // splinters
    ];

    shardDefs.forEach(({ count, minSize, maxSize, speedMult }) => {
      for (let i = 0; i < count; i++) {
        const len = minSize + Math.random() * (maxSize - minSize);
        const w = len * (0.15 + Math.random() * 0.35);
        const verts = new Float32Array([
           0,        len * 0.5,  0,
          -w * 0.5, -len * 0.5,  0,
           w * 0.5, -len * 0.5,  0,
        ]);
        const geo = new THREE.BufferGeometry();
        geo.setAttribute("position", new THREE.BufferAttribute(verts, 3));

        const b = 0.75 + Math.random() * 0.25;
        const mat = new THREE.MeshBasicMaterial({
          color: new THREE.Color(b * 0.80, b * 0.91, b),
          transparent: true,
          opacity: 0.88 + Math.random() * 0.12,
          side: THREE.DoubleSide,
        });

        const mesh = new THREE.Mesh(geo, mat);
        mesh.position.set(
          center.x + (Math.random() - 0.5) * size.x * 0.85,
          center.y + (Math.random() - 0.5) * size.y * 0.85,
          center.z + (Math.random() - 0.5) * Math.max(size.z, 0.5) * 0.4,
        );
        mesh.rotation.set(
          Math.random() * Math.PI * 2,
          Math.random() * Math.PI * 2,
          Math.random() * Math.PI * 2,
        );
        scene.add(mesh);

        const dir = mesh.position.clone().sub(center);
        if (dir.length() < 0.05) dir.set(Math.random() - 0.5, Math.random() * 0.5 + 0.5, Math.random() - 0.5);
        dir.normalize();

        const baseSpeed = (0.08 + Math.random() * 0.22) * speedMult;
        const vel = dir.multiplyScalar(baseSpeed);
        vel.y += Math.random() * 0.05 * speedMult;
        vel.x += (Math.random() - 0.5) * 0.04;
        vel.z += (Math.random() - 0.5) * 0.06;

        const faderate = 0.0015 + (1 - (len / maxSize)) * 0.003;

        shards.push({
          mesh,
          velocity: vel,
          rotSpeed: new THREE.Vector3(
            (Math.random() - 0.5) * 0.18 * speedMult,
            (Math.random() - 0.5) * 0.18 * speedMult,
            (Math.random() - 0.5) * 0.18 * speedMult,
          ),
          opacity: mat.opacity,
        });
        shards[shards.length - 1].faderate = faderate;
      }
    });

    scene.remove(character);
    return shards;
  };

  // ... rest of component (createSegment, populateImages, useEffect, animate loop with shard update, JSX)
  // Full source saved from onboardingHallway.tsx on 2026-03-28
};

export default Hero;
